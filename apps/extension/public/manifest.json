{
  "manifest_version": 3,
  "name": "ImongSpend",
  "version": "0.2.2",
  "description": "Shopee, Lazada, and Foodpanda spending estimator for Chrome.",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "extension-logo.png",
    "32": "extension-logo.png",
    "48": "extension-logo.png",
    "128": "extension-logo.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.shopee.ph/*",
    "https://*.shopee.com/*",
    "https://*.shopee.com.my/*",
    "https://*.shopee.sg/*",
    "https://*.shopee.vn/*",
    "https://*.shopee.co.id/*",
    "https://*.shopee.tw/*",
    "https://*.shopee.co.th/*",
    "https://*.shopee.com.br/*",
    "https://*.lazada.com/*",
    "https://*.lazada.com.ph/*",
    "https://*.lazada.co.id/*",
    "https://*.lazada.com.my/*",
    "https://*.lazada.sg/*",
    "https://*.lazada.vn/*",
    "https://*.lazada.co.th/*",
    "https://*.foodpanda.ph/*",
    "https://*.foodpanda.sg/*",
    "https://*.foodpanda.com.my/*",
    "https://*.foodpanda.my/*",
    "https://*.foodpanda.co.th/*",
    "https://*.foodpanda.th/*",
    "https://*.foodpanda.com.tw/*",
    "https://*.foodpanda.tw/*",
    "https://*.foodpanda.hk/*",
    "https://*.foodpanda.jp/*",
    "https://*.foodpanda.pk/*",
    "https://*.foodpanda.com.bd/*",
    "https://*.foodpanda.bd/*",
    "https://*.foodpanda.la/*",
    "https://*.foodpanda.com.kh/*",
    "https://*.foodpanda.kh/*",
    "https://*.fd-api.com/*"
  ],
  "action": {
    "default_title": "ImongSpend",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "extension-logo.png",
      "32": "extension-logo.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.shopee.ph/*",
        "https://*.shopee.com/*",
        "https://*.shopee.com.my/*",
        "https://*.shopee.sg/*",
        "https://*.shopee.vn/*",
        "https://*.shopee.co.id/*",
        "https://*.shopee.tw/*",
        "https://*.shopee.co.th/*",
        "https://*.shopee.com.br/*",
        "https://*.lazada.com/*",
        "https://*.lazada.com.ph/*",
        "https://*.lazada.co.id/*",
        "https://*.lazada.com.my/*",
        "https://*.lazada.sg/*",
        "https://*.lazada.vn/*",
        "https://*.lazada.co.th/*",
        "https://*.foodpanda.ph/*",
        "https://*.foodpanda.sg/*",
        "https://*.foodpanda.com.my/*",
        "https://*.foodpanda.my/*",
        "https://*.foodpanda.co.th/*",
        "https://*.foodpanda.th/*",
        "https://*.foodpanda.com.tw/*",
        "https://*.foodpanda.tw/*",
        "https://*.foodpanda.hk/*",
        "https://*.foodpanda.jp/*",
        "https://*.foodpanda.pk/*",
        "https://*.foodpanda.com.bd/*",
        "https://*.foodpanda.bd/*",
        "https://*.foodpanda.la/*",
        "https://*.foodpanda.com.kh/*",
        "https://*.foodpanda.kh/*"
      ],
      "js": [
        "assets/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://*.shopee.ph/*",
        "https://*.shopee.com/*",
        "https://*.shopee.com.my/*",
        "https://*.shopee.sg/*",
        "https://*.shopee.vn/*",
        "https://*.shopee.co.id/*",
        "https://*.shopee.tw/*",
        "https://*.shopee.co.th/*",
        "https://*.shopee.com.br/*",
        "https://*.lazada.com/*",
        "https://*.lazada.com.ph/*",
        "https://*.lazada.co.id/*",
        "https://*.lazada.com.my/*",
        "https://*.lazada.sg/*",
        "https://*.lazada.vn/*",
        "https://*.lazada.co.th/*",
        "https://*.foodpanda.ph/*",
        "https://*.foodpanda.sg/*",
        "https://*.foodpanda.com.my/*",
        "https://*.foodpanda.my/*",
        "https://*.foodpanda.co.th/*",
        "https://*.foodpanda.th/*",
        "https://*.foodpanda.com.tw/*",
        "https://*.foodpanda.tw/*",
        "https://*.foodpanda.hk/*",
        "https://*.foodpanda.jp/*",
        "https://*.foodpanda.pk/*",
        "https://*.foodpanda.com.bd/*",
        "https://*.foodpanda.bd/*",
        "https://*.foodpanda.la/*",
        "https://*.foodpanda.com.kh/*",
        "https://*.foodpanda.kh/*"
      ]
    }
  ]
}
