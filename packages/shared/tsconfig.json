{
  "compilerOptions": {
    "tsBuildInfoFile": "../../node_modules/.tmp/shared.tsbuildinfo",
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
